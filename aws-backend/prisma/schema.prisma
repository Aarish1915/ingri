datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  pending
  preparing
  ready
  delivered
  cancelled
  paid
}

enum OrderType {
  dine_in
  takeaway
  delivery
}

enum PaymentMethod {
  cash
  card
  upi
  online
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
}

enum Role {
  superadmin
  admin
}

enum DiscountType {
  percentage
  flat
}

enum BlogStatus {
  draft
  published
  archived
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  salt         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  orders       Order[]
  reviews      Review[]
  couponUsages CouponUsage[]
  payments     Payment[]
  addresses    Address[]

  @@index([email])
}

model Admin {
  id           String   @id @default(uuid())
  name         String   @default("Admin")
  email        String   @unique
  passwordHash String
  salt         String
  role         Role     @default(superadmin)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String
  price       Float
  image       String   @default("")
  rating      Float    @default(0)
  description String   @default("")
  inStock     Boolean  @default(true)
  quantity    Int      @default(100)
  reservedQuantity Int @default(0)
  featured    Boolean  @default(false)
  mrp         Float?
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orderItems  OrderItem[]
  productReviews Review[]
}

model Reservation {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String?
  reservationAt DateTime
  guests      Int
  occasion    String?
  request     String?
  status      ReservationStatus @default(pending)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Order {
  id            String   @id @default(uuid())
  orderId       String   @unique
  userId        String?
  customerName  String
  customerEmail String?
  customerPhone String?
  customerAddress String?
  customerPincode String?
  total         Float
  status        OrderStatus @default(pending)
  orderType     OrderType   @default(dine_in)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?    @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  couponUsages  CouponUsage[]

  @@index([status])
  @@index([orderId])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String?
  name      String
  price     Float
  quantity  Int      @default(1)
  image     String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

model Coupon {
  id             String   @id @default(uuid())
  code           String   @unique
  description    String?
  discountType   DiscountType @default(percentage)
  discountValue  Float
  minOrderAmount Float    @default(0)
  maxDiscount    Float    @default(0)
  maxRedemptions Int      @default(0)
  timesRedeemed  Int      @default(0)
  perUserLimit   Int      @default(1)
  active         Boolean  @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usages         CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String?
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id])

  @@unique([couponId, userId])
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String?
  userId        String?
  amount        Float
  method        PaymentMethod @default(cash)
  status        PaymentStatus @default(pending)
  transactionId String?
  customerName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order         Order?   @relation(fields: [orderId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])

  @@index([status])
}

model Blog {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  excerpt        String?
  content        String?
  coverImage     String?
  category       String   @default("General")
  tags           String[] 
  author         String   @default("INGRI Team")
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  status         BlogStatus @default(draft)
  featured       Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  userName  String
  rating    Int
  title     String?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Subscription {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  source    String   @default("website")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id           String   @id @default(uuid())
  title        String
  type         String   @default("scroll")
  image        String?
  content      String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Banner {
  id           String   @id @default(uuid())
  title        String
  image        String
  link         String?
  description  String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Recipe {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  excerpt     String
  image       String
  category    String
  time        String
  difficulty  String
  servings    String
  ingredients String[]
  steps       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceablePincode {
  id        String   @id @default(uuid())
  code      String   @unique
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
